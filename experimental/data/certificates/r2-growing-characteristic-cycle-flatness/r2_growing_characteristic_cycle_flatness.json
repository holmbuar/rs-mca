    "subgroup_order": "d*(p^2+1)",
    "requirement": "d>2*C_W and p=1 mod d",
    "old_cycle_hypothesis": "N/p is unbounded",
    "old_shallow_hypothesis": "2*sqrt(Q)/N tends to 2/d, not zero",
